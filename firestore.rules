rules_version = '2';

// Security rules for the Shri Fragrance order backend.
// Paste these into Firebase Console → Firestore Database → Rules → Publish.
service cloud.firestore {
  match /databases/{database}/documents {

    // The admin account (matches ADMIN_EMAILS in src/lib/auth.ts).
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email == 'admin@shrifragrance.com';
    }

    // Orders: a customer owns the orders tagged with their uid; the admin
    // can read and manage every order.
    match /orders/{orderId} {
      allow read:   if isAdmin()
                    || (request.auth != null && resource.data.uid == request.auth.uid);
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid;
      allow update: if isAdmin()
                    || (request.auth != null && resource.data.uid == request.auth.uid);
      allow delete: if isAdmin();
    }

    // Wishlist: one doc per user, named by their uid. Only that user (or the
    // admin) may read or write it.
    match /wishlists/{uid} {
      allow read, write: if isAdmin()
                         || (request.auth != null && request.auth.uid == uid);
    }
  }
}
